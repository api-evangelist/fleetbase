    "name": "Fleetbase API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "RESTful API for the Fleetbase open-source logistics and supply chain operating system.\n\nContact Support:\n Name: Fleetbase Support\n Email: hello@fleetbase.io",
      "type": "text/plain"
    }
  },
  "auth": {
    "type": "bearer",
